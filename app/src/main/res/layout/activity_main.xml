<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- WebView (tersembunyi saat loading) -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Area tap rahasia di pojok kiri atas (di atas WebView) -->
    <View
        android:id="@+id/secretTapArea"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="top|start" />

    <!-- Tombol Exit setelah kuis selesai (kanan atas, tersembunyi default) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFinishExam"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:text="Selesai ✓"
        android:textSize="12sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#00BFA5"
        android:paddingHorizontal="16dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:elevation="4dp"
        android:visibility="gone" />

    <!-- Progress bar di atas -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_gravity="top"
        android:visibility="gone" />

    <!-- Splash / Loading Screen -->
    <LinearLayout
        android:id="@+id/splashView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="#FFFFFF">

        <ImageView
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:src="@drawable/logo_splash"
            android:contentDescription="@string/app_name" />

        <ProgressBar
            android:id="@+id/splashProgress"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="24dp" />

        <TextView
            android:id="@+id/splashText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/loading_text"
            android:textColor="#555555"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Error Screen (tersembunyi default) -->
    <LinearLayout
        android:id="@+id/errorView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:visibility="gone">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/logo_splash"
            android:contentDescription="@string/app_name" />

        <TextView
            android:id="@+id/errorText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/error_connection"
            android:textColor="#D32F2F"
            android:textSize="16sp"
            android:textAlignment="center"
            android:paddingHorizontal="32dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/retry" />

    </LinearLayout>

</FrameLayout>
